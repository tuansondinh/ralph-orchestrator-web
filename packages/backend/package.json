{
  "name": "@ralph-ui/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set -a; [ -f ../../.env.local ] && . ../../.env.local; [ -f ../../.env ] && . ../../.env; set +a; tsx src/serve.ts",
    "dev:watch": "set -a; [ -f ../../.env.local ] && . ../../.env.local; [ -f ../../.env ] && . ../../.env; set +a; tsx watch src/serve.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/src/serve.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" vitest.config.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reportsDirectory=coverage",
    "complexity": "eslint \"src/**/*.ts\" --max-warnings=0 --rule \"complexity: [\\\"error\\\", 12]\"",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate:local": "drizzle-kit generate --config drizzle.config.ts",
    "db:generate:cloud": "drizzle-kit generate --config drizzle.postgres.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:local": "tsx src/db/migrate.ts",
    "db:migrate:cloud": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@ai-sdk/google": "^3.0.31",
    "@ai-sdk/openai": "^3.0.33",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.99.0",
    "@trpc/server": "^11.10.0",
    "ai": "^6.0.100",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "node-pty": "^1.1.0",
    "postgres": "^3.4.8",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
