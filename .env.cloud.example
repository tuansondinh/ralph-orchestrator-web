# Copy to .env.cloud and fill in your remote Supabase credentials.
# Run locally against remote Supabase with: npm run dev:cloud

# Backend — Supabase connection (required together for cloud mode)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Frontend — Vite exposes these to the browser (must match above)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: GitHub OAuth
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxx
# GITHUB_CALLBACK_URL=http://localhost:3003/auth/github/callback

# Optional: Model provider keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
