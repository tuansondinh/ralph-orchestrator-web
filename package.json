{
  "name": "ralph-orchestrator-web",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w @ralph-ui/backend\" \"npm run dev -w @ralph-ui/frontend\"",
    "test": "npm run test -ws",
    "typecheck": "npm run typecheck -ws",
    "test:e2e": "npm run test:e2e -w @ralph-ui/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
