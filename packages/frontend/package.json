{
  "name": "@ralph-ui/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloud": "vite --mode cloud",
    "build": "tsc -p tsconfig.json && vite build",
    "build:cloud": "tsc -p tsconfig.json && vite build --mode cloud",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts vitest.config.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reportsDirectory=coverage",
    "complexity": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 --rule \"complexity: [\\\"error\\\", 12]\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
