# App
PORT=3003
RALPH_UI_BIND_HOST=0.0.0.0
RALPH_UI_WORKSPACE_DIR=/home/app/workspaces
RALPH_UI_ALLOW_REMOTE_UNSAFE_OPS=0
LOG_LEVEL=info

# Cloud mode (required together)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# GitHub OAuth
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxx
GITHUB_CALLBACK_URL=https://your-domain.example/auth/github/callback

# Optional overrides
# RALPH_UI_ALLOWED_ORIGINS=https://your-domain.example
# RALPH_UI_STATIC_ROOT=/opt/ralph-orchestrator-web/packages/frontend/dist

# Model provider keys used by ralph on the instance
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
